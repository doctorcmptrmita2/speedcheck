# ─── Backend ─────────────────────────────────────────────────────────────────
# Port the Go server listens on
BACKEND_PORT=8080

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:3000

# Maximum duration in seconds for the download test stream
DOWNLOAD_TEST_MAX_SECONDS=10

# Maximum upload body size in bytes (200MB default)
UPLOAD_TEST_MAX_BYTES=200000000

# Enable/disable IP-based rate limiting
RATE_LIMIT_ENABLED=true

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Backend URL used by the Next.js API proxy rewrites
# In Docker Compose this should be the internal service name
NEXT_PUBLIC_API_URL=http://backend:8080
